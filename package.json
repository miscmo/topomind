{
  "name": "topomind",
  "version": "5.2.1",
  "description": "TopoMind — 可漫游拓扑知识大脑",
  "author": {
    "name": "TopoMind",
    "email": "support@topomind.app"
  },
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:mac": "vite build && electron-builder --mac",
    "build:win": "vite build && electron-builder --win",
    "build:linux": "vite build && electron-builder --linux",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.topomind.app",
    "productName": "TopoMind",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "maintainer": "TopoMind <support@topomind.app>"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@xyflow/react": "^12.4.0",
    "dompurify": "^3.4.0",
    "elkjs": "^0.9.3",
    "marked": "^12.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-git": "^3.35.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "typescript": "^5.7.3",
    "vite": "^5.2.8",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5"
  }
}
